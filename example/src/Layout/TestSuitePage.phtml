<script type="text/javascript">
  function renderRemarkd() {
    const element = document.getElementById('current-remarkd-content');
    const outputElement = document.getElementById('js-output-content');
    
    if (!outputElement) {
      return;
    }
    
    if (!window.Remarkd) {
      outputElement.innerHTML = '<div class="error">Remarkd library not loaded</div>';
      return;
    }
    
    if (element) {
      window.Remarkd.parse(element.textContent || element.innerText).then(parsed => {
        outputElement.innerHTML = parsed;
      }).catch(err => {
        outputElement.innerHTML = '<div class="error">Error: ' + err.message + '</div>';
      });
    } else {
      outputElement.innerHTML = '<div class="error">No Remarkd Content Found</div>';
    }
  }
  
  // Wait for DOM and Remarkd library to be ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() {
      // Check if Remarkd is already loaded, otherwise wait for it
      if (window.Remarkd) {
        renderRemarkd();
      } else {
        // Poll for Remarkd to be available (in case script loads after DOMContentLoaded)
        const checkRemarkd = setInterval(function() {
          if (window.Remarkd) {
            clearInterval(checkRemarkd);
            renderRemarkd();
          }
        }, 50);
        
        // Give up after 5 seconds
        setTimeout(function() {
          clearInterval(checkRemarkd);
          if (!window.Remarkd) {
            const outputElement = document.getElementById('js-output-content');
            if (outputElement) {
              outputElement.innerHTML = '<div class="error">Remarkd library failed to load</div>';
            }
          }
        }, 5000);
      }
    });
  } else {
    // DOM already loaded
    if (window.Remarkd) {
      renderRemarkd();
    } else {
      // Wait for Remarkd
      const checkRemarkd = setInterval(function() {
        if (window.Remarkd) {
          clearInterval(checkRemarkd);
          renderRemarkd();
        }
      }, 50);
      
      setTimeout(function() {
        clearInterval(checkRemarkd);
        if (!window.Remarkd) {
          const outputElement = document.getElementById('js-output-content');
          if (outputElement) {
            outputElement.innerHTML = '<div class="error">Remarkd library failed to load</div>';
          }
        }
      }, 5000);
    }
  }
</script>
</body>
